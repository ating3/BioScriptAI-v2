{
  "manifest_version": 3,
  "name": "Bioscript",
  "version": "1.0.0",
  "description": "Academic paper research assistant — context-aware intelligence for scientific reading.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Open Bioscript",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://pubmed.ncbi.nlm.nih.gov/*",
        "https://arxiv.org/*",
        "https://www.nature.com/*",
        "https://www.science.org/*",
        "https://www.cell.com/*",
        "https://www.biorxiv.org/*",
        "https://www.medrxiv.org/*",
        "https://pmc.ncbi.nlm.nih.gov/*",
        "https://journals.plos.org/*",
        "https://elifesciences.org/*",
        "<all_urls>"
      ],
      "js": ["content/content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
